   "source": [
    "def natural(sum,N):\n",
    "    if N == 0:\n",
    "        return\n",
    "    last = N % 10\n",
    "    sum += last\n",
    "    number = N//10\n",
    "    natural(sum,number)\n",
    "    return sum\n",
    "\n",
    "num = int(input())\n",
    "n = natural(0,num)"
   ]
  },
