   "source": [
    "def onetoN(i,n):\n",
    "    if i > n:\n",
    "        return \n",
    "    print(i)\n",
    "    onetoN(i+1,n)\n",
    "\n",
    "num = int(input())\n",
    "onetoN(1,num)"
   ]
  },
