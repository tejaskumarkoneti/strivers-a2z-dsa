   "source": [
    "def nameN(i,n):\n",
    "    if i < 1:\n",
    "        return\n",
    "    nameN(i-1,n)\n",
    "    print(i,end=\" \")\n",
    "\n",
    "num = int(input())\n",
    "nameN(num,num)"
   ]
  }
