{
  "cells": [
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "frequency-array-method",
      "metadata": {},
      "outputs": [],
      "source": [
        "class FrequencyCounter:\\n",
        "    def countFreq(self, arr):\\n",
        "\\n",
        "        n = len(arr)                     # Length of array\\n",
        "\\n",
        "        # Create frequency array\\n",
        "        freq_count = [0] * (max(arr) + 1)\\n",
        "\\n",
        "        # Count frequencies\\n",
        "        for num in arr:\\n",
        "            freq_count[num] += 1\\n",
        "\\n",
        "        maxFreq = float(\\"-inf\\")\\n",
        "        minFreq = float(\\"inf\\")\\n",
        "\\n",
        "        maxEle = 0\\n",
        "        minEle = 0\\n",
        "\\n",
        "        # Traverse frequency array\\n",
        "        for i in range(len(freq_count)):\\n",
        "\\n",
        "            # Ignore elements with 0 frequency\\n",
        "            if freq_count[i] > 0:\\n",
        "\\n",
        "                # Update highest frequency\\n",
        "                if freq_count[i] > maxFreq:\\n",
        "                    maxFreq = freq_count[i]\\n",
        "                    maxEle = i\\n",
        "\\n",
        "                # Update lowest frequency\\n",
        "                if freq_count[i] < minFreq:\\n",
        "                    minFreq = freq_count[i]\\n",
        "                    minEle = i\\n",
        "\\n",
        "        print(\\"The highest frequency element is:\\", maxEle)\\n",
        "        print(\\"The lowest frequency element is:\\", minEle)\\n",
        "\\n",
        "\\n",
        "if __name__ == \\"__main__\\":\\n",
        "    fc = FrequencyCounter()\\n",
        "    arr = [10, 5, 10, 15, 10, 5]\\n",
        "    fc.countFreq(arr)\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "visited-array-method",
      "metadata": {},
      "outputs": [],
      "source": [
        "class FrequencyCounter:\\n",
        "    def countFreq(self, arr):\\n",
        "        n = len(arr)\\n",
        "        visited = [False] * n\\n",
        "\\n",
        "        maxFreq = 0\\n",
        "        minFreq = n\\n",
        "\\n",
        "        maxEle = 0\\n",
        "        minEle = 0\\n",
        "\\n",
        "        for i in range(n):\\n",
        "\\n",
        "            if visited[i]:\\n",
        "                continue\\n",
        "\\n",
        "            count = 1\\n",
        "\\n",
        "            for j in range(i + 1, n):\\n",
        "                if arr[i] == arr[j]:\\n",
        "                    visited[j] = True\\n",
        "                    count += 1\\n",
        "\\n",
        "            if count > maxFreq:\\n",
        "                maxFreq = count\\n",
        "                maxEle = arr[i]\\n",
        "\\n",
        "            if count < minFreq:\\n",
        "                minFreq = count\\n",
        "                minEle = arr[i]\\n",
        "\\n",
        "        print(\\"The highest frequency element is:\\", maxEle)\\n",
        "        print(\\"The lowest frequency element is:\\", minEle)\\n",
        "\\n",
        "\\n",
        "if __name__ == \\"__main__\\":\\n",
        "    fc = FrequencyCounter()\\n",
        "    arr = [10, 5, 10, 15, 10, 5]\\n",
        "    fc.countFreq(arr)\\n"
      ]
    }
  ],
